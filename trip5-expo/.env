# Google Maps API key (required for map + Places search)
# Get it from: https://console.cloud.google.com/google/maps-apis/
# Enable: Maps SDK for Android, Maps SDK for iOS, Places API
GOOGLE_MAPS_API_KEY=your_api_key_here
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key_here

# Backend API URL
EXPO_PUBLIC_API_BASE_URL=https://trip5-backend.onrender.com
                         
