# Supabase (Project Settings → API — use anon key in the app only)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Google Maps (Maps SDK + Places)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key
# Backend API (e.g. Render — no trailing slash)
EXPO_PUBLIC_API_BASE_URL=https://your-service.onrender.com
